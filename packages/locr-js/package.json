{
  "name": "locr",
  "version": "0.1.0",
  "description": "Local OCR for Node.js, browsers, and edge runtimes. No cloud APIs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KevRojo/locr.git",
    "directory": "packages/locr-js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "node --test dist/test.js"
  },
  "dependencies": {
    "tesseract.js": "^6.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
